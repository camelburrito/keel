{
  "_comment": "Source of truth for all colors, spacing, typography, motion. Codegen emits per-platform files via scripts/gen-tokens.mjs. See keel playbook 02-design-system.md.",
  "color": {
    "background": { "primary": "#FFFFFF", "secondary": "#F5F5F7" },
    "ink": { "primary": "#0A0A0A", "muted": "#6B6B6B" },
    "accent": { "primary": "#0066FF" },
    "status": {
      "success": "#1A8F3C",
      "warning": "#B8860B",
      "error": "#C62828"
    }
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "xxl": "48px"
  },
  "radii": {
    "sm": "4px",
    "md": "8px",
    "lg": "16px",
    "round": "9999px"
  },
  "borders": {
    "default": "1px",
    "thick": "2px"
  },
  "typography": {
    "fontFamily": {
      "system": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif"
    },
    "fontSize": {
      "sm": "14px",
      "md": "16px",
      "lg": "20px",
      "xl": "28px"
    },
    "fontWeight": {
      "regular": 400,
      "semibold": 600,
      "bold": 700
    }
  },
  "motion": {
    "duration": {
      "fast": "120ms",
      "normal": "200ms",
      "slow": "320ms"
    }
  },
  "media": {
    "_comment": "Documented breakpoints. Defended by no-undocumented-breakpoints ratchet.",
    "tablet": { "minWidth": "768px", "platforms": ["web"] },
    "desktop": { "minWidth": "1024px", "platforms": ["web"] }
  }
}
