# Production environment configuration.
# Copy to .env.<APP>-prod and fill in real values.
# Never commit the filled file — it's in .gitignore.

# Sentry env routing (web + CF tagging)
VITE_APP_ENV=prod

# Firebase web SDK config (per-project)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=auth.<APP>.org
VITE_FIREBASE_PROJECT_ID=<APP>-prod
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Sentry DSN (per-env)
VITE_SENTRY_DSN=

# Google Analytics measurement ID (per-env)
VITE_GA_MEASUREMENT_ID=

# CF-side observability (consumed by firebase deploy --only functions)
SENTRY_DSN=
